<Window x:Class="SJMagic.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SJMagic"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Top: Menu -->
            <RowDefinition Height="*"/>    <!-- Center: Main Content -->
            <RowDefinition Height="Auto"/> <!-- Splitter -->
            <RowDefinition Height="180"/>  <!-- Bottom: Logs -->
        </Grid.RowDefinitions>

        <!-- Top Menu -->
        <Menu Grid.Row="0">
            <MenuItem Header="File">
                <MenuItem Header="Open Folder" Click="MenuItem_Click"/>
                <MenuItem Header="Save"/>
                <Separator/>
                <MenuItem Header="Exit" Click="MenuExit_Click"/>
            </MenuItem>
            <MenuItem Header="Edit"/>
            <MenuItem Header="View"/>
            <MenuItem Header="Help"/>
        </Menu>

        <!-- Main Content (Middle) -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="150"/> <!-- Left: File List -->
                <ColumnDefinition Width="Auto"/>             <!-- Splitter -->
                <ColumnDefinition Width="*"/>                <!-- Center: Image -->
                <ColumnDefinition Width="Auto"/>             <!-- Splitter -->
                <ColumnDefinition Width="180" MinWidth="120"/> <!-- Right: Buttons -->
            </Grid.ColumnDefinitions>

            <!-- Left: File List -->
            <Grid Grid.Column="0" Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="File List" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" Margin="5,0,0,5"/>
                <ListBox x:Name="lbFiles" Grid.Row="1" DisplayMemberPath="Name" SelectionChanged="lbFiles_SelectionChanged">
                </ListBox>
            </Grid>

            <!-- Splitter 1 -->
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="Transparent"/>

            <!-- Center: Image Viewer -->
            <Border Grid.Column="2" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0" Background="#11111B">
                <Grid>
                    <TextBlock Text="Image Preview Area" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#44475A" FontSize="18"/>
                    <Image x:Name="imgDisplay" Margin="20" Stretch="Uniform">
                        <!-- Placeholder for logic -->
                        <Image.Effect>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="0" Opacity="0.5"/>
                        </Image.Effect>
                    </Image>
                </Grid>
            </Border>

            <!-- Splitter 2 -->
            <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="Transparent"/>

            <!-- Right: Action Buttons -->
            <Grid Grid.Column="4" Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Actions" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" Margin="5,0,0,5"/>
                <StackPanel Grid.Row="1">
                    <Button x:Name="btnAbout" Content="✨ About SJMagic" Click="btnAbout_Click" Height="40" FontSize="14" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Splitter 3 -->
        <GridSplitter Grid.Row="2" Height="4" HorizontalAlignment="Stretch" VerticalAlignment="Center" Background="Transparent"/>

        <!-- Bottom: Logs -->
        <Grid Grid.Row="3" Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <StackPanel Orientation="Horizontal" Margin="5,0,0,3">
                <TextBlock Text="Output Log" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold"/>
                <TextBlock x:Name="tbLogStatus" Text=" - Ready" Foreground="#6272A4" FontSize="11" Margin="10,2,0,0"/>
            </StackPanel>
            <TextBox x:Name="txtLog" Grid.Row="1" IsReadOnly="True" VerticalScrollBarVisibility="Visible" 
                     TextWrapping="Wrap" AcceptsReturn="True" 
                     FontFamily="Consolas" FontSize="12"/>
        </Grid>
    </Grid>
</Window>
